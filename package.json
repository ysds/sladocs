{
  "name": "sladocs",
  "version": "0.1.0",
  "description": "Zero-install Markdown preview server powered by fumadocs",
  "license": "MIT",
  "author": "ysds",
  "homepage": "https://sladocs.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysds/sladocs.git"
  },
  "bugs": {
    "url": "https://github.com/ysds/sladocs/issues"
  },
  "keywords": [
    "markdown",
    "preview",
    "docs",
    "documentation",
    "fumadocs",
    "mdx",
    "cli"
  ],
  "type": "module",
  "bin": {
    "sladocs": "./dist/lib/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "waku build && tsdown",
    "build:app": "waku build",
    "build:lib": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@fumadocs/base-ui": "^16.9.1",
    "@hono/node-server": "^2.0.4",
    "@hono/node-ws": "^1.3.1",
    "beautiful-mermaid": "^1.1.3",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "^16.9.1",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "hono": "^4.12.23",
    "ignore": "^7.0.5",
    "katex": "0.17.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "tinyglobby": "^0.2.16",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "waku": "1.0.0-beta.0",
    "yaml": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  }
}
