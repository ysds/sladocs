{
  "name": "sladocs",
  "version": "0.2.0",
  "description": "Zero-install Markdown preview server powered by fumadocs",
  "license": "MIT",
  "author": "ysds",
  "homepage": "https://sladocs.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysds/sladocs.git",
    "directory": "packages/sladocs"
  },
  "bugs": {
    "url": "https://github.com/ysds/sladocs/issues"
  },
  "keywords": [
    "markdown",
    "preview",
    "docs",
    "documentation",
    "fumadocs",
    "mdx",
    "cli"
  ],
  "type": "module",
  "bin": {
    "sladocs": "./dist/lib/cli/index.mjs"
  },
  "files": [
    "dist",
    "src",
    "waku.config.ts",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "waku build && tsdown",
    "build:app": "waku build",
    "build:lib": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "catalog:"
  },
  "devDependencies": {
    "@fumadocs/base-ui": "catalog:",
    "@hono/node-server": "^2.0.4",
    "@hono/node-ws": "^1.3.1",
    "@tailwindcss/vite": "catalog:",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "beautiful-mermaid": "catalog:",
    "chokidar": "^5.0.0",
    "flexsearch": "catalog:",
    "fumadocs-core": "catalog:",
    "hast-util-to-jsx-runtime": "catalog:",
    "hono": "^4.12.23",
    "ignore": "catalog:",
    "katex": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rehype-katex": "catalog:",
    "rehype-raw": "catalog:",
    "remark": "catalog:",
    "remark-gfm": "catalog:",
    "remark-math": "catalog:",
    "remark-rehype": "catalog:",
    "tailwindcss": "catalog:",
    "tinyglobby": "catalog:",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "unified": "catalog:",
    "unist-util-visit": "catalog:",
    "vfile": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.8",
    "waku": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  }
}
